        <property name="text">
         <string>📚 Fundamentação Teórica</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QLabel" name="labelTextoTeoria">
        <property name="styleSheet">
         <string>font-size: 15px; color: #2C3E40; line-height: 1.6;</string>
        </property>
        <property name="text">
         <string>&lt;b&gt;Paulo Freire:&lt;/b&gt; Educação como espaço de diálogo e transformação.&lt;br&gt;
&lt;b&gt;Maria Helena Souza Patto:&lt;/b&gt; Olhar crítico sobre a psicologia escolar e as condições sociais dos alunos.&lt;br&gt;
&lt;b&gt;Jean Piaget:&lt;/b&gt; Desenvolvimento cognitivo e fases da aprendizagem.&lt;br&gt;
&lt;b&gt;Lev Vygotsky:&lt;/b&gt; Mediação social e zona de desenvolvimento proximal.&lt;br&gt;
&lt;b&gt;Sigmund Freud:&lt;/b&gt; Complexidades emocionais e raízes do comportamento.&lt;br&gt;
&lt;b&gt;Carl Rogers:&lt;/b&gt; Psicologia humanista, empatia e aceitação no ambiente escolar.</string>
        </property>
        <property name="textFormat">
         <enum>Qt::TextFormat::RichText</enum>
        </property>
        <property name="wordWrap">
