      </item>
      <item>
       <widget class="QLabel" name="labelTextoODS">
        <property name="styleSheet">
         <string>font-size: 15px; color: #2C3E40; line-height: 1.6;</string>
        </property>
        <property name="text">
         <string>Este projeto contribui para os ODS da ONU:&lt;br&gt;&lt;br&gt;
&lt;b&gt;ODS 3 – Saúde e Bem-Estar:&lt;/b&gt; Facilitando o acesso ao suporte psicológico e promovendo a saúde mental dos estudantes.&lt;br&gt;&lt;br&gt;
&lt;b&gt;ODS 4 – Educação de Qualidade:&lt;/b&gt; Criando um ambiente escolar mais propício ao desenvolvimento integral.&lt;br&gt;&lt;br&gt;
&lt;b&gt;ODS 10 – Redução das Desigualdades:&lt;/b&gt; Garantindo que todos os estudantes da rede pública tenham acesso equitativo ao apoio psicológico.</string>
        </property>
        <property name="textFormat">
         <enum>Qt::TextFormat::RichText</enum>
        </property>
