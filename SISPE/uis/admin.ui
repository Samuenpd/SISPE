<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>AdminScreen</class>
 <widget class="QWidget" name="AdminScreen">
  <property name="styleSheet">
   <string notr="true">#AdminScreen { 
     background-color: #F0EAD6;
     font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, sans-serif;
   }</string>
  </property>
  <layout class="QVBoxLayout" name="verticalLayout">
   <property name="spacing"><number>24</number></property>
   <property name="leftMargin"><number>32</number></property>
   <property name="topMargin"><number>32</number></property>
   <property name="rightMargin"><number>32</number></property>
   <property name="bottomMargin"><number>32</number></property>

   <!-- Título Principal -->
   <item>
    <widget class="QLabel" name="labelTitulo">
     <property name="text">
      <string>&lt;b&gt;Painel Administrativo - Gerenciamento de Usuários&lt;/b&gt;</string>
     </property>
     <property name="styleSheet">
      <string notr="true">QLabel {
        font-size: 24px;
        color: #2C3E40;
        margin-bottom: 8px;
        padding: 0px;
      }</string>
     </property>
     <property name="alignment">
      <set>Qt::AlignCenter</set>
     </property>
    </widget>
   </item>

   <!-- Card de Estatísticas -->
   <item>
    <widget class="QFrame" name="frameStats">
     <property name="styleSheet">
      <string notr="true">#frameStats {
        background: #FAF9F6;
        border-radius: 16px;
        border: 1px solid #A3C1AD;
        padding: 24px;
      }</string>
     </property>
     <layout class="QHBoxLayout" name="layoutStats">
      <property name="spacing"><number>16</number></property>
      <item>
       <widget class="QLabel" name="labelInfo">
        <property name="text">
         <string>&lt;b&gt;📊 Total: 0 | 👨‍👩‍👧 Pais: 0 | 🧠 Psicólogos: 0&lt;/b&gt;</string>
        </property>
        <property name="styleSheet">
         <string notr="true">QLabel { 
           font-size: 16px; 
           color: #2C3E40; 
           padding: 12px 20px;
           background: rgba(74, 124, 146, 0.1);
           border-radius: 10px;
         }</string>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>

   <!-- Frame Criar Usuário -->
   <item>
    <widget class="QFrame" name="frameCriarUsuario">
     <property name="styleSheet">
      <string notr="true">#frameCriarUsuario {
        background: #FAF9F6;
        border-radius: 16px;
        border: 1px solid #A3C1AD;
        padding: 24px;
      }</string>
     </property>
     <layout class="QGridLayout" name="gridLayoutCriar">
      <property name="spacing"><number>16</number></property>
      <item row="0" column="0">
       <widget class="QLabel" name="labelUsername">
        <property name="text"><string>&lt;b&gt;Username&lt;/b&gt;</string></property>
        <property name="styleSheet"><string notr="true">QLabel { color: #5B7B7D; font-size: 13px; margin-bottom: 4px; }</string></property>
       </widget>
      </item>
      <item row="0" column="1">
       <widget class="QLabel" name="labelSenha">
        <property name="text"><string>&lt;b&gt;Senha&lt;/b&gt;</string></property>
        <property name="styleSheet"><string notr="true">QLabel { color: #5B7B7D; font-size: 13px; margin-bottom: 4px; }</string></property>
       </widget>
      </item>
      <item row="0" column="2">
       <widget class="QLabel" name="labelTipo">
        <property name="text"><string>&lt;b&gt;Tipo de Usuário&lt;/b&gt;</string></property>
        <property name="styleSheet"><string notr="true">QLabel { color: #5B7B7D; font-size: 13px; margin-bottom: 4px; }</string></property>
       </widget>
      </item>
      
      <item row="1" column="0">
       <widget class="QLineEdit" name="inputUsername">
        <property name="placeholderText"><string>Digite o username</string></property>
        <property name="styleSheet">
         <string notr="true">QLineEdit {
           border: 2px solid #A3C1AD;
           border-radius: 10px;
           padding: 12px 16px;
           background-color: #FFFFFF;
           color: #2C3E40;
           font-size: 15px;
           min-height: 44px;
         }
         QLineEdit:focus { 
           border: 2px solid #4A7C92; 
           background-color: #FAF9F6;
         }
         QLineEdit::placeholder { color: #95A5A6; }</string>
        </property>
       </widget>
      </item>
      <item row="1" column="1">
       <widget class="QLineEdit" name="inputSenha">
        <property name="placeholderText"><string>Digite a senha</string></property>
        <property name="styleSheet">
         <string notr="true">QLineEdit {
           border: 2px solid #A3C1AD;
           border-radius: 10px;
           padding: 12px 16px;
           background-color: #FFFFFF;
           color: #2C3E40;
           font-size: 15px;
           min-height: 44px;
         }
         QLineEdit:focus { 
           border: 2px solid #4A7C92; 
           background-color: #FAF9F6;
         }
         QLineEdit::placeholder { color: #95A5A6; }</string>
        </property>
       </widget>
      </item>
      <item row="1" column="2">
       <widget class="QComboBox" name="comboTipo">
        <property name="styleSheet">
         <string notr="true">QComboBox {
           padding: 12px 16px;
           border-radius: 10px;
           border: 2px solid #A3C1AD;
           background-color: #FFFFFF;
           color: #2C3E40;
           font-size: 15px;
           min-height: 44px;
         }
         QComboBox:focus { 
           border: 2px solid #4A7C92; 
           background-color: #FAF9F6;
         }
         QComboBox::drop-down { border: none; width: 20px; }
         QComboBox::down-arrow {
           image: none;
           border-left: 5px solid transparent;
           border-right: 5px solid transparent;
           border-top: 8px solid #5B7B7D;
         }
         QComboBox QAbstractItemView {
           border: 1px solid #A3C1AD;
           border-radius: 8px;
           background-color: white;
           selection-background-color: #E6F0F3;
           color: #2C3E40;
         }</string>
        </property>
        <item><property name="text"><string>👨‍👩‍👧 Pai</string></property></item>
        <item><property name="text"><string>🧠 Psicólogo</string></property></item>
       </widget>
      </item>
      
      <item row="1" column="3" alignment="Qt::AlignRight">
       <widget class="QPushButton" name="btnCriarUsuario">
        <property name="text"><string>➕ Criar Usuário</string></property>
        <property name="styleSheet">
         <string notr="true">QPushButton {
           background-color: #4A7C92;
           color: white;
           border: none;
           border-radius: 12px;
           padding: 14px 28px;
           font-weight: 600;
           font-size: 15px;
           min-width: 160px;
           min-height: 48px;
         }
         QPushButton:hover { 
           background-color: #5E8FA3;
         }
         QPushButton:pressed { 
           background-color: #3B6270;
         }</string>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>

   <!-- Frame da Tabela (EXPANSÍVEL) -->
   <item>
    <widget class="QFrame" name="frameTabela">
     <property name="sizePolicy">
      <sizepolicy hsizetype="Expanding" vsizetype="Expanding">
       <horstretch>0</horstretch>
       <verstretch>1</verstretch>
      </sizepolicy>
     </property>
     <property name="styleSheet">
      <string notr="true">#frameTabela {
        background: #FAF9F6;
        border-radius: 16px;
        border: 1px solid #A3C1AD;
      }</string>
     </property>
     <layout class="QVBoxLayout" name="layoutTabela">
      <property name="spacing"><number>12</number></property>
      <property name="leftMargin"><number>24</number></property>
      <property name="topMargin"><number>24</number></property>
      <property name="rightMargin"><number>24</number></property>
      <property name="bottomMargin"><number>24</number></property>
      <item>
       <widget class="QLabel" name="labelTabela">
        <property name="text"><string>&lt;b&gt;Lista de Usuários Cadastrados&lt;/b&gt;</string></property>
        <property name="styleSheet"><string notr="true">QLabel { 
          font-size: 18px; 
          color: #2C3E40; 
          padding: 8px 0px;
          margin-bottom: 12px;
        }</string></property>
       </widget>
      </item>
      <item>
       <widget class="QLineEdit" name="inputBusca">
        <property name="placeholderText"><string>🔍 Pesquisar usuário por username...</string></property>
        <property name="styleSheet">
         <string notr="true">QLineEdit {
           border: 2px solid #A3C1AD;
           border-radius: 10px;
           padding: 12px 16px;
           background-color: #FFFFFF;
           color: #2C3E40;
           font-size: 15px;
           min-height: 44px;
           margin-bottom: 12px;
         }
         QLineEdit:focus { 
           border: 2px solid #4A7C92; 
           background-color: #FAF9F6;
         }
         QLineEdit::placeholder { color: #95A5A6; }</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QTableWidget" name="tabelaUsuarios">
        <property name="sizePolicy">
         <sizepolicy hsizetype="Expanding" vsizetype="Expanding">
          <horstretch>0</horstretch>
          <verstretch>1</verstretch>
         </sizepolicy>
        </property>
        <property name="verticalScrollBarPolicy"><enum>Qt::ScrollBarAlwaysOff</enum></property>
        <property name="horizontalScrollBarPolicy"><enum>Qt::ScrollBarAsNeeded</enum></property>
        <property name="alternatingRowColors"><bool>true</bool></property>
        <property name="styleSheet">
         <string notr="true">QTableWidget {
           background: transparent;
           gridline-color: #E6F0F3;
           font-size: 14px;
           border: none;
           selection-background-color: #FAF9F6;
         }
         QTableWidget::item {
           padding: 12px;
           border-bottom: 1px solid #E6F0F3;
         }
         QTableWidget::item:selected {
           background-color: #A3C1AD;
           color: #FFFFFF;
         }
         QHeaderView::section {
           background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
           stop:0 #4A7C92, stop:1 #3B6270);
           padding: 16px 12px;
           border: none;
           font-weight: 600;
           font-size: 14px;
           color: #FAF9F6;
           border-bottom: 2px solid #A3C1AD;
         }
         QHeaderView::section:hover {
           background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
           stop:0 #5E8FA3, stop:1 #4A7C92);
         }
         QTableCornerButton::section {
           background: #3B6270;
           border: none;
         }</string>
        </property>
        <column><property name="text"><string>Username</string></property></column>
        <column><property name="text"><string>Tipo</string></property></column>
        <column><property name="text"><string>Ações</string></property></column>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
  </layout>
 </widget>
