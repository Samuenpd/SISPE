<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>PsicologoScreen</class>
 <widget class="QWidget" name="PsicologoScreen">
  <property name="styleSheet">
   <string notr="true">#PsicologoScreen { 
     background: qlineargradient(x1:0, y1:0, x2:1, y2:1, 
     stop:0 #e8f0fe, stop:1 #f0f4f8);
     font-family: 'Segoe UI', Arial, sans-serif;
   }</string>
  </property>
  <layout class="QVBoxLayout" name="verticalLayout">
   <property name="spacing"><number>24</number></property>
   <property name="leftMargin"><number>32</number></property>
   <property name="topMargin"><number>32</number></property>
   <property name="rightMargin"><number>32</number></property>
   <property name="bottomMargin"><number>32</number></property>

   <!-- Título Principal -->
   <item>
    <widget class="QLabel" name="labelTitulo">
     <property name="text">
      <string>&lt;b&gt;Cadastro de Alunos - Atendimento Psicológico&lt;/b&gt;</string>
     </property>
     <property name="styleSheet">
      <string notr="true">QLabel {
        font-size: 24px;
        color: #1e293b;
        margin-bottom: 8px;
        padding: 0px;
      }</string>
     </property>
     <property name="alignment">
      <set>Qt::AlignCenter</set>
     </property>
    </widget>
   </item>

   <!-- Frame de Cadastro Melhorado -->
   <item>
    <widget class="QFrame" name="frameCadastro">
     <property name="styleSheet">
      <string notr="true">#frameCadastro {
        background: qlineargradient(x1:0, y1:0, x2:1, y2:1, 
        stop:0 #ffffff, stop:1 #f8fafc);
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        padding: 24px;
      }</string>
     </property>
     <layout class="QGridLayout" name="gridLayoutCadastro">
      <property name="spacing"><number>16</number></property>
      <item row="0" column="0">
       <widget class="QLabel" name="labelNome">
        <property name="text"><string>&lt;b&gt;Nome do Aluno&lt;/b&gt;</string></property>
        <property name="styleSheet"><string notr="true">QLabel { color: #475569; font-size: 13px; margin-bottom: 4px; }</string></property>
       </widget>
      </item>
      <item row="0" column="1">
       <widget class="QLabel" name="labelSala">
        <property name="text"><string>&lt;b&gt;Sala&lt;/b&gt;</string></property>
        <property name="styleSheet"><string notr="true">QLabel { color: #475569; font-size: 13px; margin-bottom: 4px; }</string></property>
       </widget>
      </item>
      <item row="0" column="2">
       <widget class="QLabel" name="labelSerie">
        <property name="text"><string>&lt;b&gt;Série&lt;/b&gt;</string></property>
        <property name="styleSheet"><string notr="true">QLabel { color: #475569; font-size: 13px; margin-bottom: 4px; }</string></property>
       </widget>
      </item>
      <item row="0" column="3">
       <widget class="QLabel" name="labelGravidade">
        <property name="text"><string>&lt;b&gt;Gravidade&lt;/b&gt;</string></property>
        <property name="styleSheet"><string notr="true">QLabel { color: #475569; font-size: 13px; margin-bottom: 4px; }</string></property>
       </widget>
      </item>
      <item row="1" column="0">
       <widget class="QLineEdit" name="inputNome">
        <property name="placeholderText"><string>Digite o nome completo do aluno</string></property>
        <property name="styleSheet">
         <string notr="true">QLineEdit {
           border: 2px solid #e2e8f0;
           border-radius: 10px;
           padding: 12px 16px;
           background-color: #ffffff;
           color: #1e293b;
           font-size: 15px;
           min-height: 44px;
         }
         QLineEdit:focus { 
           border: 2px solid #3b82f6; 
           background-color: #fafbff;
         }
         QLineEdit::placeholder { color: #94a3b8; }</string>
        </property>
       </widget>
      </item>
      <item row="1" column="1">
       <widget class="QLineEdit" name="inputSala">
        <property name="placeholderText"><string>Ex: A101</string></property>
        <property name="styleSheet">
         <string notr="true">QLineEdit {
           border: 2px solid #e2e8f0;
           border-radius: 10px;
           padding: 12px 16px;
           background-color: #ffffff;
           color: #1e293b;
           font-size: 15px;
           min-height: 44px;
         }
         QLineEdit:focus { 
           border: 2px solid #3b82f6; 
           background-color: #fafbff;
         }
         QLineEdit::placeholder { color: #94a3b8; }</string>
        </property>
       </widget>
      </item>
      <item row="1" column="2">
       <widget class="QLineEdit" name="inputSerie">
        <property name="placeholderText"><string>Ex: 9º ano</string></property>
        <property name="styleSheet">
         <string notr="true">QLineEdit {
           border: 2px solid #e2e8f0;
           border-radius: 10px;
           padding: 12px 16px;
           background-color: #ffffff;
           color: #1e293b;
           font-size: 15px;
           min-height: 44px;
         }
         QLineEdit:focus { 
           border: 2px solid #3b82f6; 
           background-color: #fafbff;
         }
         QLineEdit::placeholder { color: #94a3b8; }</string>
        </property>
       </widget>
      </item>
      <item row="1" column="3">
       <widget class="QComboBox" name="comboGravidade">
        <property name="styleSheet">
         <string notr="true">QComboBox {
           padding: 12px 16px;
           border-radius: 10px;
           border: 2px solid #e2e8f0;
           background-color: #ffffff;
           color: #1e293b;
           font-size: 15px;
           min-height: 44px;
         }
         QComboBox:focus { 
           border: 2px solid #3b82f6; 
           background-color: #fafbff;
         }
         QComboBox::drop-down {
           border: none;
           width: 20px;
         }
         QComboBox::down-arrow {
           image: none;
           border-left: 5px solid transparent;
           border-right: 5px solid transparent;
           border-top: 8px solid #64748b;
         }
         QComboBox QAbstractItemView {
           border: 1px solid #e2e8f0;
           border-radius: 8px;
           background-color: white;
           selection-background-color: #3b82f6;
         }</string>
        </property>
        <item><property name="text"><string>Baixo</string></property></item>
        <item><property name="text"><string>Médio</string></property></item>
        <item><property name="text"><string>Grave</string></property></item>
       </widget>
      </item>
      <item row="1" column="4" alignment="Qt::AlignRight">
       <widget class="QPushButton" name="btnCadastrar">
        <property name="text"><string>➕ Cadastrar Aluno</string></property>
        <property name="styleSheet">
         <string notr="true">QPushButton {
           background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
           stop:0 #4f46e5, stop:1 #3730a3);
           color: white;
           border-radius: 12px;
           padding: 14px 28px;
           font-weight: 600;
           font-size: 15px;
           border: none;
           min-width: 160px;
           min-height: 48px;
         }
         QPushButton:hover { 
           background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
           stop:0 #4338ca, stop:1 #312e81);
         }
         QPushButton:pressed { 
           background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
           stop:0 #3730a3, stop:1 #312e81);
         }</string>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>

   <!-- Frame da Tabela (EXPANSÍVEL) -->
   <item>
    <widget class="QFrame" name="frameTabela">
     <property name="sizePolicy">
      <sizepolicy hsizetype="Expanding" vsizetype="Expanding">
       <horstretch>0</horstretch>
       <verstretch>1</verstretch>
      </sizepolicy>
     </property>
     <property name="styleSheet">
      <string notr="true">#frameTabela {
        background: white;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
      }</string>
     </property>
     <layout class="QVBoxLayout" name="layoutTabela">
      <property name="spacing"><number>12</number></property>
      <property name="leftMargin"><number>24</number></property>
      <property name="topMargin"><number>24</number></property>
      <property name="rightMargin"><number>24</number></property>
      <property name="bottomMargin"><number>24</number></property>
      <item>
       <widget class="QLabel" name="labelTabela">
        <property name="text"><string>&lt;b&gt;Lista de Alunos Cadastrados&lt;/b&gt;</string></property>
        <property name="styleSheet"><string notr="true">QLabel { 
          font-size: 18px; 
          color: #1e293b; 
          padding: 8px 0px;
          margin-bottom: 12px;
        }</string></property>
       </widget>
      </item>
      <item>
       <widget class="QLineEdit" name="inputBusca">
        <property name="placeholderText"><string>Pesquisar aluno por nome...</string></property>
        <property name="styleSheet">
         <string notr="true">QLineEdit {
           border: 2px solid #e2e8f0;
           border-radius: 10px;
           padding: 12px 16px;
           background-color: #ffffff;
           color: #1e293b;
           font-size: 15px;
           min-height: 44px;
           margin-bottom: 12px;
         }
         QLineEdit:focus { 
           border: 2px solid #3b82f6; 
           background-color: #fafbff;
         }</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QTableWidget" name="tabelaAlunos">
        <property name="sizePolicy">
         <sizepolicy hsizetype="Expanding" vsizetype="Expanding">
          <horstretch>0</horstretch>
          <verstretch>1</verstretch>
         </sizepolicy>
        </property>
        <property name="verticalScrollBarPolicy">
         <enum>Qt::ScrollBarAsNeeded</enum>
        </property>
        <property name="horizontalScrollBarPolicy">
         <enum>Qt::ScrollBarAsNeeded</enum>
        </property>
        <property name="alternatingRowColors"><bool>true</bool></property>
        <property name="styleSheet">
         <string notr="true">QTableWidget {
           background: transparent;
           gridline-color: #f1f5f9;
           font-size: 14px;
           border: none;
           selection-background-color: #dbeafe;
         }
         QTableWidget::item {
           padding: 12px;
           border-bottom: 1px solid #f1f5f9;
         }
         QTableWidget::item:selected {
           background-color: #3b82f6;
           color: white;
         }
         QHeaderView::section {
           background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
           stop:0 #f8fafc, stop:1 #e2e8f0);
           padding: 16px 12px;
           border: none;
           font-weight: 600;
           font-size: 14px;
           color: #374151;
           border-bottom: 2px solid #e2e8f0;
         }
         QHeaderView::section:hover {
           background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
           stop:0 #f1f5f9, stop:1 #e2e8f0);
         }
         QTableCornerButton::section {
           background: #f8fafc;
           border: none;
         }</string>
        </property>
        <column><property name="text"><string>Nome</string></property></column>
        <column><property name="text"><string>Sala</string></property></column>
        <column><property name="text"><string>Série</string></property></column>
        <column><property name="text"><string>Gravidade</string></property></column>
        <column><property name="text"><string>Data</string></property></column>
       </widget>
      </item>
     </layout>
    </widget>
   </item>

   <!-- Barra de Status -->
   <item>
    <widget class="QFrame" name="frameStatus">
     <property name="styleSheet">
      <string notr="true">#frameStatus {
        background: rgba(255,255,255,0.8);
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        padding: 12px;
      }</string>
     </property>
     <layout class="QHBoxLayout" name="layoutStatus">
      <property name="spacing"><number>16</number></property>
      <item>
       <widget class="QLabel" name="labelStatus">
        <property name="text"><string>Bem-vindo ao sistema de atendimento psicológico</string></property>
        <property name="styleSheet"><string notr="true">QLabel { color: #64748b; font-size: 13px; }</string></property>
       </widget>
      </item>
      <item alignment="Qt::AlignRight">
       <widget class="QPushButton" name="btnLimpar">
        <property name="text"><string>🗑️ Limpar Tudo</string></property>
        <property name="styleSheet">
         <string notr="true">QPushButton {
           background: #f8fafc;
           color: #64748b;
           border: 1px solid #e2e8f0;
           border-radius: 8px;
           padding: 8px 16px;
           font-size: 13px;
         }
         QPushButton:hover { background: #f1f5f9; }</string>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
  </layout>
 </widget>
